http {
    # Define cache path, size, and maximum inactive time
    proxy_cache_path /var/cache/nginx/nexus levels=1:2 keys_zone=nexus_cache:200m max_size=10g inactive=30d use_temp_path=off;
    proxy_temp_path /var/cache/nginx/nexus_temp;

    # Map to bypass cache for non-GET/HEAD requests and the Nexus UI
    map $request_method $cache_bypass {
        default 0;
        POST    1;
        PUT     1;
        DELETE  1;
    }

    server {
        listen 443 ssl http2;
        server_name ://example.com;

        # SSL Configuration
        ssl_certificate /etc/ssl/certs/nexus.crt;
        ssl_certificate_key /etc/ssl/certs/nexus.key;

        # Large file upload limits (e.g., Docker layers, large binaries)
        client_max_body_size 2G;
        proxy_connect_timeout 600s;
        proxy_read_timeout 600s;
        
        location / {
            # Route to Nexus
            proxy_pass http://localhost:8081;

            # Caching Directives
            proxy_cache nexus_cache;
            proxy_cache_valid 200 302 304 30d;
            proxy_cache_valid 404 1m;
            proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
            proxy_cache_background_update on;
            proxy_cache_lock on;
            
            # Bypass cache for authenticated or state-changing requests
            proxy_cache_bypass $cache_bypass;
            proxy_no_cache $cache_bypass;

            # Proxy Headers
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            # Enable chunked transfer encoding for large artifacts
            chunked_transfer_encoding on;
        }
    }
}
